{
	"name": "skinshi-monorepo",
	"version": "1.0.0",
	"private": true,
	"description": "Skinshi monorepo - App, Services, and Workers",
	"packageManager": "pnpm@10.8.1",
	"engines": {
		"node": ">=20.0.0",
		"pnpm": ">=9.0.0"
	},
	"scripts": {
		"dev": "turbo run dev",
		"dev:app": "turbo run dev --filter=@skinshi/web",
		"dev:mobile": "turbo run dev --filter=@skinshi/mobile",
		"dev:services": "turbo run dev --filter='@skinshi/*-service'",
		"dev:workers": "turbo run dev --filter='@skinshi/*-worker'",
		"build": "turbo run build",
		"build:app": "turbo run build --filter=@skinshi/web",
		"build:mobile": "turbo run build --filter=@skinshi/mobile",
		"vercel-build": "turbo run build --filter=@skinshi/web",
		"lint": "turbo run lint",
		"typecheck": "turbo run typecheck",
		"deploy": "turbo run deploy --filter=@skinshi/auth-worker",
		"db:migrate": "cd workers/auth && pnpm db:migrate",
		"clean": "turbo run clean && pnpm exec rimraf '**/node_modules' '**/.next' '**/dist' '**/.turbo' '**/*.tsbuildinfo'",
		"fresh": "pnpm clean && pnpm install"
	},
	"devDependencies": {
		"@skinshi/eslint-config": "workspace:*",
		"@skinshi/typescript-config": "workspace:*",
		"next": "16.2.1",
		"turbo": "^2.5.2",
		"typescript": "^5.9.3"
	}
}
