{
	"$schema": "https://json.schemastore.org/tsconfig",
	"display": "Next.js",
	"extends": "./base.json",
	"compilerOptions": {
		"plugins": [{ "name": "next" }],
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"allowJs": true,
		"declaration": false,
		"declarationMap": false,
		"incremental": true,
		"jsx": "preserve",
		"lib": ["dom", "dom.iterable", "ES2022"],
		"noEmit": true,
		"paths": {
			"@/*": ["./*"]
		},
		"resolveJsonModule": true
	},
	"include": ["src", ".next/types/**/*.ts"],
	"exclude": ["node_modules"]
}
